-- Function to get avatar assets
local function getUserAssets(userId)
    local success, assetsString = pcall(function()
        return Players:GetCharacterAppearanceAsync(userId)
    end)

    if success and assetsString then
        return assetsString
    else
        warn("Failed to get avatar appearance for userId:", userId)
        return nil
    end
end

local function parseAssetsString(assetsString)
    local assets = {}
    for asset in string.gmatch(assetsString, "[^,]+") do
        table.insert(assets, asset)
    end
    return assets
end

local function applyAssets(assets)
    -- Remove current clothing/accessories
    for _, item in ipairs(character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
            item:Destroy()
        end
    end

    -- Apply assets
    for _, assetIdStr in ipairs(assets) do
        local assetId = tonumber(assetIdStr)
        if assetId then
            local success, assetModel = pcall(function()
                return InsertService:LoadAsset(assetId)
            end)
            if success and assetModel then
                for _, item in ipairs(assetModel:GetChildren()) do
                    if item:IsA("Accessory") then
                        item.Parent = character
                    elseif item:IsA("Shirt") or item:IsA("Pants") then
                        item.Parent = character
                    end
                end
            end
        end
    end
end

-- Button click to fetch and apply outfit
LoadButton.MouseButton1Click:Connect(function()
    local userIdStr = InputBox.Text
    local userId = tonumber(userIdStr)
    if not userId then
        warn("Invalid User ID")
        return
    end

    local assetsString = getUserAssets(userId)
    if assetsString then
        local assets = parseAssetsString(assetsString)
        applyAssets(assets)
    end
end)
