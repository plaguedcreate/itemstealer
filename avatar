-- Function to fetch avatar assets and apply them
local function fetchAndApplyAvatar(userId)
    -- Fetch avatar asset IDs
    local success, assetsString = pcall(function()
        return Players:GetCharacterAppearanceAsync(userId)
    end)
    if success and assetsString then
        -- Parse asset IDs
        local assetIds = {}
        for asset in string.gmatch(assetsString, "[^,]+") do
            table.insert(assetIds, tonumber(asset))
        end

        -- Remove existing clothes/accessories
        for _, item in ipairs(character:GetChildren()) do
            if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
                item:Destroy()
            end
        end

        -- Load and attach assets
        for _, id in ipairs(assetIds) do
            local success, asset = pcall(function()
                return InsertService:LoadAsset(id)
            end)
            if success and asset then
                for _, child in ipairs(asset:GetChildren()) do
                    if child:IsA("Accessory") then
                        child.Parent = character
                    elseif child:IsA("Shirt") or child:IsA("Pants") then
                        child.Parent = character
                    end
                end
            end
        end
        print("Outfit loaded for User ID:", userId)
    else
        warn("Failed to fetch avatar assets for User ID:", userId)
    end
end

-- Button event
LoadButton.MouseButton1Click:Connect(function()
    local userIdStr = InputBox.Text
    local userIdNum = tonumber(userIdStr)
    if not userIdNum then
        warn("Invalid User ID")
        return
    end
    fetchAndApplyAvatar(userIdNum)
end)
