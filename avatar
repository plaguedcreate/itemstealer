local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- Create GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "OutfitSwitcherGui"
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 300, 0, 150)
Frame.Position = UDim2.new(0.5, -150, 0.5, -75)
Frame.BackgroundColor3 = Color3.new(0, 0, 0)
Frame.BorderSizePixel = 0
Frame.Parent = ScreenGui

-- Make draggable
local UserInputService = game:GetService("UserInputService")
local dragging = false
local dragStart, startPos

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)

Frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

Frame.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = startPos + UDim2.new(0, delta.X, 0, delta.Y)
    end
end)

-- Title Label
local Title = Instance.new("TextLabel")
Title.Text = "Outfit Loader"
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundColor3 = Color3.new(0, 0, 0)
Title.TextColor3 = Color3.new(0, 1, 0)
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 20
Title.Parent = Frame

-- Input box for User ID
local InputBox = Instance.new("TextBox")
InputBox.PlaceholderText = "Enter User ID"
InputBox.Size = UDim2.new(1, -20, 0, 30)
InputBox.Position = UDim2.new(0, 10, 0, 40)
InputBox.BackgroundColor3 = Color3.new(0, 0, 0)
InputBox.TextColor3 = Color3.new(0, 1, 0)
InputBox.Font = Enum.Font.SourceSans
InputBox.TextSize = 18
InputBox.ClearTextOnFocus = false
InputBox.Text = ""
InputBox.Parent = Frame

-- Load Button
local LoadButton = Instance.new("TextButton")
LoadButton.Text = "Load Outfit"
LoadButton.Size = UDim2.new(1, -20, 0, 40)
LoadButton.Position = UDim2.new(0, 10, 0, 80)
LoadButton.BackgroundColor3 = Color3.new(0, 0, 0)
LoadButton.TextColor3 = Color3.new(0, 1, 0)
LoadButton.Font = Enum.Font.SourceSansBold
LoadButton.TextSize = 20
LoadButton.Parent = Frame

-- Function to load and apply outfit using HumanoidDescription
local function loadOutfitFromUserId(userId)
    local success, description = pcall(function()
        return Players:GetHumanoidDescriptionFromUserId(userId)
    end)
    if success and description then
        -- Apply the description to your humanoid
        humanoid:ApplyDescription(description)
    else
        warn("Failed to get humanoid description for UserId:", userId)
    end
end

-- Button click event
LoadButton.MouseButton1Click:Connect(function()
    local userIdStr = InputBox.Text
    local userId = tonumber(userIdStr)
    if not userId then
        warn("Invalid User ID")
        return
    end
    loadOutfitFromUserId(userId)
end)
