InputBox.TextSize = 18
InputBox.ClearTextOnFocus = false
InputBox.Text = ""
InputBox.Parent = Frame

-- Load button
local LoadButton = Instance.new("TextButton")
LoadButton.Text = "Load Outfit"
LoadButton.Size = UDim2.new(1, -20, 0, 40)
LoadButton.Position = UDim2.new(0, 10, 0, 80)
LoadButton.BackgroundColor3 = Color3.new(0,0,0)
LoadButton.TextColor3 = Color3.new(0,1,0)
LoadButton.Font = Enum.Font.SourceSansBold
LoadButton.TextSize = 20
LoadButton.Parent = Frame

-- Function to fetch avatar asset IDs
local function fetchAvatarAssets(userId)
    local success, assetsString = pcall(function()
        return Players:GetCharacterAppearanceAsync(userId)
    end)
    if success and assetsString then
        return assetsString
    else
        warn("Failed to fetch avatar assets for User ID:", userId)
        return nil
    end
end

-- Function to parse asset IDs from string
local function parseAssets(assetsString)
    local assets = {}
    for asset in string.gmatch(assetsString, "[^,]+") do
        table.insert(assets, tonumber(asset))
    end
    return assets
end

-- Function to load an asset by ID
local function loadAsset(assetId)
    local success, asset = pcall(function()
        return InsertService:LoadAsset(assetId)
    end)
    if success and asset then
        return asset
    else
        warn("Failed to load asset ID:", assetId)
        return nil
    end
end

-- Function to clear current clothing/accessories
local function clearCurrentOutfit()
    for _, item in ipairs(character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
            item:Destroy()
        end
    end
end

-- Function to apply assets to character
local function applyAssets(assetIds)
    clearCurrentOutfit()
    for _, id in ipairs(assetIds) do
        local asset = loadAsset(id)
        if asset then
            for _, item in ipairs(asset:GetChildren()) do
                if item:IsA("Accessory") then
                    item.Parent = character
                elseif item:IsA("Shirt") or item:IsA("Pants") then
                    item.Parent = character
                end
            end
        end
    end
end

