local function Color3FromHex(hex)
    local r = tonumber(hex:sub(1,2), 16)/255
    local g = tonumber(hex:sub(3,4), 16)/255
    local b = tonumber(hex:sub(5,6), 16)/255
    return Color3.new(r,g,b)
end

local function fetchUserAvatar(userId)
    local url = "https://avatar.roblox.com/v1/users/" .. userId .. "/avatar"
    local success, response = pcall(function()
        return HttpService:GetAsync(url)
    end)
    if success then
        local data = HttpService:JSONDecode(response)
        return data
    else
        warn("Failed to fetch avatar data")
        return nil
    end
end

local function applyAvatar(avatarData)
    if not avatarData or not avatarData.assets then return end

    -- Remove existing clothing/accessories
    for _, item in ipairs(character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
            item:Destroy()
        end
    end

    -- Apply Shirt
    if avatarData.assets.shirt then
        local shirt = Instance.new("Shirt")
        shirt.ShirtTemplate = avatarData.assets.shirt
        shirt.Parent = character
    end

    -- Apply Pants
    if avatarData.assets.pants then
        local pants = Instance.new("Pants")
        pants.PantsTemplate = avatarData.assets.pants
        pants.Parent = character
    end

    -- Apply Accessories
    if avatarData.assets.accessories then
        for _, accessoryId in ipairs(avatarData.assets.accessories) do
            local success, accessoryAsset = pcall(function()
                return InsertService:LoadAsset(accessoryId)
            end)
            if success and accessoryAsset then
                for _, item in ipairs(accessoryAsset:GetChildren()) do
                    if item:IsA("Accessory") then
                        item.Parent = character
                    end
                end
            end
        end
    end

    -- Apply BodyColors
    if avatarData.assets.bodyColors then
        local colors = avatarData.assets.bodyColors
        local bodyColors = Instance.new("BodyColors")
        bodyColors.HeadColor = Color3FromHex(colors.headColor)
        bodyColors.LeftArmColor = Color3FromHex(colors.leftArmColor)
        bodyColors.RightArmColor = Color3FromHex(colors.rightArmColor)
        bodyColors.LeftLegColor = Color3FromHex(colors.leftLegColor)
        bodyColors.RightLegColor = Color3FromHex(colors.rightLegColor)
        bodyColors.TorsoColor = Color3FromHex(colors.torsoColor)
        bodyColors.Parent = character
    end
end

-- Button click handler
LoadButton.MouseButton1Click:Connect(function()
    local userIdStr = InputBox.Text
    local userId = tonumber(userIdStr)
    if not userId then
        warn("Invalid User ID")
        return
    end
    local avatarData = fetchUserAvatar(userId)
    if avatarData then
        applyAvatar(avatarData)
    end
end)
